# ===== OpenLIT Configuration =====
TELEMETRY_ENABLED=true
OPENLIT_PORT=3000

# Database configuration (if using external DB)
# INIT_DB_HOST=your_db_host
# INIT_DB_PORT=9000
# INIT_DB_DATABASE=openlit
# INIT_DB_USERNAME=default
# INIT_DB_PASSWORD=your_password

# Demo account (optional)
DEMO_ACCOUNT_EMAIL=demo@vostok.local
DEMO_ACCOUNT_PASSWORD=demo123

# ===== OTEL Configuration =====
# OTEL_DB_HOST=your_clickhouse_host
# OTEL_DB_PORT=9000
# OTEL_DB_SECURE=false

# ===== Vostok API Configuration =====
# Required API keys
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=vostok-documents

ANTHROPIC_API_KEY=your_anthropic_api_key_here
VOYAGE_API_KEY=your_voyage_api_key_here

# ===== Network Configuration =====
# EC2 instance IP for CORS
VOSTOK_HOST=34.225.86.252
CORS_ORIGINS=http://localhost:3000,http://34.225.86.252,http://34.225.86.252:8080

# ===== Logging =====
LOG_LEVEL=INFO
